# Project Prometheus - Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Google Workspace Integration (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Microsoft 365 Integration (Optional)
MICROSOFT_TENANT_ID=your_tenant_id
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret

# Model Paths
FACE_LANDMARK_MODEL=models/shape_predictor_68_face_landmarks.dat
FACE_RECOGNITION_MODEL=models/facenet.h5

# Database (Optional - for chain of custody persistence)
DATABASE_URL=sqlite:///./prometheus.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/prometheus.log

# Analysis Configuration
MAX_FILE_SIZE=104857600
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/heic
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/avi
ALLOWED_DOCUMENT_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document
